<Window x:Class="DuckGo.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        Title="DuckGo"
        Width="1720" Height="910"
        MinWidth="900" MinHeight="600"
        WindowStyle="SingleBorderWindow"
        AllowsTransparency="False"
        ResizeMode="CanResize"
        WindowStartupLocation="CenterScreen"
        Background="#2d2d30">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="1"
                      UseAeroCaptionButtons="False" />
    </WindowChrome.WindowChrome>

    <Border x:Name="RootBorder" Background="#2d2d30">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="40" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <!-- Custom TitleBar -->
            <Border Grid.Row="0" Background="#2d2d30">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="15,0,0,0" VerticalAlignment="Center">
                        <!-- DuckGo Logo -->
                        <Border Width="20" Height="20" CornerRadius="4" Margin="0,0,8,0" VerticalAlignment="Center">
                            <Border.Background>
                                <SolidColorBrush Color="#265E6AD2" />
                            </Border.Background>
                            <Border.BorderBrush>
                                <SolidColorBrush Color="#665E6AD2" />
                            </Border.BorderBrush>
                            <Border.BorderThickness>1</Border.BorderThickness>
                            <Path Data="M 7,6 C 7,5 8,5 9,5 C 13,5 17,8 17,15 C 17,22 13,25 9,25 C 8,25 7,25 7,24 L 7,15 L 10,15 L 10,24 C 10,24 10.5,25 11,25 C 13,25 15,22 15,15 C 15,8 13,6 11,6 Z M 10,8 L 10,12 L 12,12 L 12,8 Z"
                                  Fill="#5E6AD2" Stretch="Uniform" Width="10" Height="10" HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <TextBlock Text="DuckGo" FontWeight="SemiBold" FontSize="14" Foreground="#e0e0e0" VerticalAlignment="Center"/>
                        <TextBlock Text=" Automation" FontSize="14" Foreground="#888" VerticalAlignment="Center"/>
                    </StackPanel>

                    <!-- Spacer -->
                    <Border Grid.Column="1" Background="Transparent" />

                    <!-- Window Controls -->
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Top" Margin="0,0,10,0">
                        <StackPanel.Resources>
                            <Style TargetType="Button">
                                <Setter Property="Width" Value="32"/>
                                <Setter Property="Height" Value="32"/>
                                <Setter Property="Background" Value="Transparent"/>
                                <Setter Property="BorderThickness" Value="0"/>
                                <Setter Property="Foreground" Value="#aaa"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="Button">
                                            <Border Background="{TemplateBinding Background}" CornerRadius="4">
                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            </Border>
                                            <ControlTemplate.Triggers>
                                                <Trigger Property="IsMouseOver" Value="True">
                                                    <Setter Property="Background" Value="#3a3a3c"/>
                                                    <Setter Property="Foreground" Value="#fff"/>
                                                </Trigger>
                                            </ControlTemplate.Triggers>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                            <Style x:Key="CloseButtonStyle" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
                                <Style.Triggers>
                                    <Trigger Property="IsMouseOver" Value="True">
                                        <Setter Property="Background" Value="#e81123"/>
                                        <Setter Property="Foreground" Value="White"/>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Resources>

                        <Button Click="BtnMinimize_Click" Margin="0,4,2,0" WindowChrome.IsHitTestVisibleInChrome="True" ToolTip="Minimize">
                            <TextBlock Text="&#xE921;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                        </Button>
                        <Button x:Name="BtnMaximize" Click="BtnMaximize_Click" Margin="0,4,2,0" WindowChrome.IsHitTestVisibleInChrome="True" ToolTip="Maximize">
                            <Grid x:Name="MaximizeIcon">
                                <TextBlock Text="&#xE922;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                            </Grid>
                        </Button>
                        <Button Click="BtnClose_Click" Style="{StaticResource CloseButtonStyle}" Margin="0,4,0,0" WindowChrome.IsHitTestVisibleInChrome="True" ToolTip="Close">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe MDL2 Assets" FontSize="10"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Rectangle Grid.Row="0" Height="1" Fill="#2c2c2e" VerticalAlignment="Bottom" />

            <!-- ===== Content Area (WebView2) ===== -->
            <Border x:Name="webViewWrapper" Grid.Row="1" Background="#F4F6F8">
                <wv2:WebView2 x:Name="WebView" />
            </Border>
        </Grid>
    </Border>
</Window>
